---
import Tag from "./Tag.astro";
import Icon from "./Icon.astro";

interface Props {
    title: string;
    href: string;
    description?: string;
    date?: string;
    authors?: string;
    extraInput?: string;
    tags?: string[];
    externalUrl?: string;
    image?: string;
}

const { title, href, description, date, authors, extraInput, tags, externalUrl, image } = Astro.props;
---

<article class="item-card">
    {image && (
        <div class="mb-4">
            <img src={image} alt={title} class="w-full h-48 object-cover rounded-lg" />
        </div>
    )}
    <div class="item-content">
        <a href={href} class="item-title">
            <h3>{title}</h3>
        </a>

        <div class="item-meta flex gap-4 text-sm opacity-75">
            {date && (
                <span class="flex items-center gap-1">
                    <Icon name="Calendar" size={14} />
                    <span>{date}</span>
                </span>
            )}
            {authors && (
                <span class="flex items-center gap-1">
                    <Icon name="User" size={14} />
                    <span>{authors}</span>
                </span>
            )}
        </div>

        {
            tags && tags.length > 0 && (
                <div class="tags flex gap-3 flex-wrap my-4">
                    {tags.map((tag) => (
                        <Tag name={tag} size="sm" />
                    ))}
                </div>
            )
        }

        {description && <p class="opacity-80 line-clamp-3">{description}</p>}
    </div>

    {
        externalUrl && (
            <div class="item-links">
                <a href={externalUrl} target="_blank">
                    View &rarr;
                </a>
            </div>
        )
    }
</article>