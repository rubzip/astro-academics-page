---
export interface TimelineItemData {
    title: string;
    period: string;
    subtitle: string;
    description?: string;
    thesis?: string;
}

interface Props {
    items: TimelineItemData[];
}

const { items } = Astro.props;
---

<div class="timeline flex flex-col">
    {
        items.map((item) => (
            <div class="timeline-item flex gap-8">
                <div class="timeline-marker flex flex-col items-center shrink-0">
                    <div class="dot w-3 h-3 rounded-full bg-accent mt-2 z-10" />
                    <div class="timeline-line flex-1 w-[2px] bg-border my-2" />
                </div>
                <div class="timeline-content pb-14 flex-1">
                    <div class="entry-header flex justify-between items-baseline gap-4 mb-2">
                        <h3 class="text-xl font-bold transition-colors duration-200 leading-tight">
                            {item.title}
                        </h3>
                        <span class="period text-sm opacity-75 font-bold whitespace-nowrap">
                            {item.period}
                        </span>
                    </div>
                    <div class="subtitle font-bold text-lg opacity-90">
                        {item.subtitle}
                    </div>
                    {item.description && (
                        <div class="desc mt-4 leading-relaxed opacity-80">
                            {item.description}
                        </div>
                    )}
                    {item.thesis && (
                        <div class="thesis mt-4 italic opacity-80">
                            Thesis: {item.thesis}
                        </div>
                    )}
                </div>
            </div>
        ))
    }
</div>
