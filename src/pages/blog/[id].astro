---
import { getCollection } from "astro:content";
import BaseDetail from "../../layouts/BaseDetail.astro";
import { getReadingTime } from "../../utils/readingTime";

export async function getStaticPaths() {
    const posts = await getCollection("posts");
    const sortedPosts = posts.sort(
        (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
    );

    return sortedPosts.map((post, i) => ({
        params: { id: post.id },
        props: {
            post,
            prevPost: i > 0 ? sortedPosts[i - 1] : null,
            nextPost: i < sortedPosts.length - 1 ? sortedPosts[i + 1] : null,
        },
    }));
}

const { post, prevPost, nextPost } = Astro.props;
const readingTime = `${getReadingTime(post.body || "")} min read`;
---

<BaseDetail collection="posts" id={post.id} readingTime={readingTime}>
    <nav
        slot="footer"
        class="post-navigation container-narrow flex justify-between mt-24 pt-12 border-t border-dashed border-border gap-8"
    >
        {
            prevPost && (
                <a
                    href={`/blog/${prevPost.id}`}
                    class="nav-prev flex flex-col group max-w-[45%] no-underline"
                >
                    <span class="nav-label text-[0.8rem] uppercase tracking-wider text-text-muted font-bold mb-2">
                        &larr; Previous Post
                    </span>
                    <span class="nav-title text-lg font-semibold text-foreground group-hover:text-accent transition-colors duration-200 leading-snug">
                        {prevPost.data.title}
                    </span>
                </a>
            )
        }
        <div class="nav-spacer flex-1"></div>
        {
            nextPost && (
                <a
                    href={`/blog/${nextPost.id}`}
                    class="nav-next flex flex-col items-end text-right group max-w-[45%] no-underline"
                >
                    <span class="nav-label text-[0.8rem] uppercase tracking-wider text-text-muted font-bold mb-2">
                        Next Post &rarr;
                    </span>
                    <span class="nav-title text-lg font-semibold text-foreground group-hover:text-accent transition-colors duration-200 leading-snug">
                        {nextPost.data.title}
                    </span>
                </a>
            )
        }
    </nav>
</BaseDetail>
