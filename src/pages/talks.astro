---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";

const talks = await getCollection("talks");
const sortedTalks = talks.sort(
    (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);
---

<Layout title="Talks">
    <header>
        <h1>Talks & Presentations</h1>
        <p class="subtitle">
            Presentations given at various institutions and conferences.
        </p>
    </header>

    <section class="talks-list">
        {
            sortedTalks.map((talk) => (
                <article class="talk-item">
                    <div class="talk-content">
                        <a
                            href={talk.data.slides || talk.data.video}
                            target="_blank"
                            class="post-link"
                        >
                            <h3>{talk.data.title}</h3>
                        </a>
                        <div class="post-meta">
                            <span class="date">
                                {talk.data.date.toLocaleDateString("en-US", {
                                    year: "numeric",
                                    month: "long",
                                    day: "numeric",
                                })}
                            </span>
                        </div>
                        <p class="event">
                            <strong>{talk.data.event}</strong>
                        </p>
                        <p class="location">{talk.data.location}</p>
                        <p class="description">{talk.data.description || ""}</p>
                    </div>
                    <div class="talk-links">
                        {talk.data.slides && (
                            <a href={talk.data.slides} target="_blank">
                                Slides &rarr;
                            </a>
                        )}
                        {talk.data.video && (
                            <a href={talk.data.video} target="_blank">
                                Video &rarr;
                            </a>
                        )}
                    </div>
                </article>
            ))
        }
    </section>
</Layout>

<style>
    h1 {
        font-size: 2.5rem;
        font-weight: 800;
        margin: 0;
    }
    .subtitle {
        font-size: 1.1rem;
        color: var(--text-muted);
        margin-top: 0.5rem;
        margin-bottom: 3rem;
    }
    .talks-list {
        display: flex;
        flex-direction: column;
        gap: 3.5rem;
    }
    .talk-item {
        padding-bottom: 2.5rem;
        border-bottom: 1px dashed var(--border);
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 2rem;
    }
    .talk-item:last-child {
        border-bottom: none;
    }
    .talk-content {
        flex: 1;
    }
    .post-meta {
        margin-bottom: 0.75rem;
    }
    .date {
        font-size: 0.9rem;
        color: var(--text-muted);
        font-weight: 500;
    }
    .post-link {
        text-decoration: none;
        color: inherit;
    }
    .post-link:hover h3 {
        color: var(--accent);
        text-decoration: underline;
    }
    h3 {
        font-size: 1.75rem;
        margin: 0;
        line-height: 1.2;
        font-weight: 700;
        letter-spacing: -0.01em;
    }
    .event {
        margin-top: 1rem;
        margin-bottom: 0.25rem;
        font-weight: 600;
    }
    .location {
        color: var(--text-muted);
        margin-bottom: 1rem;
        font-size: 0.95rem;
    }
    .description {
        margin-top: 1rem;
        line-height: 1.6;
        opacity: 0.8;
    }
    .talk-links {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        flex-shrink: 0;
        text-align: right;
        min-width: 120px;
    }
    .talk-links a {
        text-decoration: none;
        font-size: 0.9rem;
        font-weight: 700;
        color: var(--foreground);
        transition: color 0.2s;
        white-space: nowrap;
    }
    .talk-links a:hover {
        color: var(--accent);
        text-decoration: underline;
    }
</style>
