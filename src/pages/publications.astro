---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";

const publications = await getCollection("publications");
const sortedPublications = publications.sort(
    (a, b) =>
        b.data.publicationDate.getTime() - a.data.publicationDate.getTime(),
);
---

<Layout title="Publications">
    <header>
        <h1>Publications</h1>
        <p class="subtitle">
            A collection of my research papers and contributions to physics.
        </p>
    </header>

    <section class="publications-list">
        {
            sortedPublications.map((pub) => (
                <article class="publication-item">
                    <div class="publication-content">
                        <a
                            href={
                                pub.data.url ||
                                pub.data.pdf ||
                                `https://doi.org/${pub.data.doi}`
                            }
                            target="_blank"
                            class="post-link"
                        >
                            <h3>{pub.data.title}</h3>
                        </a>
                        <div class="post-meta">
                            <span class="date">
                                {pub.data.publicationDate.toLocaleDateString(
                                    "en-US",
                                    {
                                        year: "numeric",
                                        month: "long",
                                        day: "numeric",
                                    },
                                )}
                            </span>
                        </div>
                        <p class="authors">{pub.data.authors.join(", ")}</p>
                        {pub.data.journal && (
                            <p class="journal">
                                <em>{pub.data.journal}</em>
                            </p>
                        )}
                        <p class="description">{pub.data.description || ""}</p>
                    </div>
                    <div class="publication-links">
                        {pub.data.doi && (
                            <a
                                href={`https://doi.org/${pub.data.doi}`}
                                target="_blank"
                            >
                                DOI &rarr;
                            </a>
                        )}
                        {pub.data.url && (
                            <a href={pub.data.url} target="_blank">
                                Publisher &rarr;
                            </a>
                        )}
                        {pub.data.pdf && (
                            <a href={pub.data.pdf} target="_blank">
                                PDF &rarr;
                            </a>
                        )}
                    </div>
                </article>
            ))
        }
    </section>
</Layout>

<style>
    h1 {
        font-size: 2.5rem;
        font-weight: 800;
        margin: 0;
    }
    .subtitle {
        font-size: 1.1rem;
        color: var(--text-muted);
        margin-top: 0.5rem;
        margin-bottom: 3rem;
    }
    .publications-list {
        display: flex;
        flex-direction: column;
        gap: 3.5rem;
    }
    .publication-item {
        padding-bottom: 2.5rem;
        border-bottom: 1px dashed var(--border);
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 2rem;
    }
    .publication-item:last-child {
        border-bottom: none;
    }
    .publication-content {
        flex: 1;
    }
    .post-meta {
        margin-bottom: 0.75rem;
    }
    .date {
        font-size: 0.9rem;
        color: var(--text-muted);
        font-weight: 500;
    }
    .post-link {
        text-decoration: none;
        color: inherit;
    }
    .post-link:hover h3 {
        color: var(--accent);
        text-decoration: underline;
    }
    h3 {
        font-size: 1.75rem;
        margin: 0;
        line-height: 1.2;
        font-weight: 700;
        letter-spacing: -0.01em;
    }
    .authors {
        font-weight: 600;
        margin-top: 1rem;
        margin-bottom: 0.25rem;
        opacity: 0.9;
    }
    .journal {
        color: var(--text-muted);
        margin-bottom: 1rem;
        font-size: 0.95rem;
    }
    .description {
        margin-top: 1rem;
        line-height: 1.6;
        opacity: 0.8;
    }
    .publication-links {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        flex-shrink: 0;
        text-align: right;
        min-width: 120px;
    }
    .publication-links a {
        text-decoration: none;
        font-size: 0.9rem;
        font-weight: 700;
        color: var(--foreground);
        transition: color 0.2s;
        white-space: nowrap;
    }
    .publication-links a:hover {
        color: var(--accent);
        text-decoration: underline;
    }
</style>
