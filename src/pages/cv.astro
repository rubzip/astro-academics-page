---
import { getEntry, render } from "astro:content";
import Layout from "../layouts/Layout.astro";

const cvEntry = await getEntry("cv", "cv");
if (!cvEntry) {
    throw new Error(
        "CV content not found. Please ensure src/content/cv.md exists.",
    );
}

const { Content } = await render(cvEntry);
const { name, title, experience = [], education = [] } = cvEntry.data;
---

<Layout title="CV">
    <header class="page-header">
        <h1 class="page-title">Curriculum Vitae</h1>
        <p class="page-subtitle">{name} — {title}</p>
    </header>

    <div class="container-narrow">
        {
            experience.length > 0 && (
                <section class="cv-section mb-16">
                    <h2 class="text-2xl font-bold border-b border-border pb-2 mb-10 opacity-90">
                        Professional Experience
                    </h2>
                    <div class="timeline flex flex-col">
                        {experience.map((exp) => (
                            <div class="timeline-item flex gap-8">
                                <div class="timeline-marker flex flex-col items-center shrink-0">
                                    <div class="dot w-3 h-3 rounded-full bg-accent mt-2 z-10" />
                                    <div class="line flex-1 w-[2px] bg-border my-2" />
                                </div>
                                <div class="timeline-content pb-14 flex-1">
                                    <div class="entry-header flex justify-between items-baseline gap-4 mb-2">
                                        <h3 class="text-xl font-bold transition-colors duration-200 leading-tight">
                                            {exp.role}
                                        </h3>
                                        <span class="period text-sm text-text-muted font-bold whitespace-nowrap">
                                            {exp.period}
                                        </span>
                                    </div>
                                    <div class="institution font-bold text-lg opacity-90">
                                        {exp.institution}
                                    </div>
                                    <div class="desc mt-4 leading-relaxed opacity-80">
                                        {exp.description}
                                    </div>
                                </div>
                            </div>
                        ))}
                    </div>
                </section>
            )
        }

        {
            education.length > 0 && (
                <section class="cv-section mb-16">
                    <h2 class="text-2xl font-bold border-b border-border pb-2 mb-10 opacity-90">
                        Education
                    </h2>
                    <div class="timeline flex flex-col">
                        {education.map((edu) => (
                            <div class="timeline-item flex gap-8">
                                <div class="timeline-marker flex flex-col items-center shrink-0">
                                    <div class="dot w-3 h-3 rounded-full bg-accent mt-2 z-10" />
                                    <div class="line flex-1 w-[2px] bg-border my-2" />
                                </div>
                                <div class="timeline-content pb-14 flex-1">
                                    <div class="entry-header flex justify-between items-baseline gap-4 mb-2">
                                        <h3 class="text-xl font-bold transition-colors duration-200 leading-tight">
                                            {edu.degree}
                                        </h3>
                                        <span class="period text-sm text-text-muted font-bold whitespace-nowrap">
                                            {edu.period}
                                        </span>
                                    </div>
                                    <div class="institution font-bold text-lg opacity-90">
                                        {edu.institution}
                                    </div>
                                    {edu.description && (
                                        <div class="desc mt-4 leading-relaxed opacity-80">
                                            {edu.description}
                                        </div>
                                    )}
                                    {edu.thesis && (
                                        <div class="thesis mt-4 italic opacity-80">
                                            Thesis: {edu.thesis}
                                        </div>
                                    )}
                                </div>
                            </div>
                        ))}
                    </div>
                </section>
            )
        }

        <div class="prose max-w-none">
            <Content />
        </div>
    </div>
</Layout>

<style>
    .timeline-item:last-child .line {
        display: none;
    }
    .timeline-item:last-child .timeline-content {
        padding-bottom: 0;
    }
</style>
