---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";

const projects = await getCollection("projects");
---

<Layout title="Projects">
    <header>
        <h1>Code & Projects</h1>
        <p class="subtitle">
            A selection of technical projects and software experiments.
        </p>
    </header>

    <section class="projects-list">
        {
            projects.map((project) => (
                <article class="project-item">
                    <div class="project-content">
                        <div class="post-link-wrapper">
                            <a
                                href={`/projects/${project.id}`}
                                class="post-link"
                            >
                                <h3>{project.data.title}</h3>
                            </a>
                        </div>
                        <div class="tech-stack">
                            {project.data.tech?.map((t, index) => (
                                <span class="tech-item">
                                    {t}
                                    {index <
                                    (project.data.tech?.length ?? 0) - 1
                                        ? " • "
                                        : ""}
                                </span>
                            ))}
                        </div>
                        <p>{project.data.description}</p>
                    </div>
                    <div class="project-links">
                        {project.data.github && (
                            <a href={project.data.github} target="_blank">
                                GitHub &rarr;
                            </a>
                        )}
                        <a
                            href={`/projects/${project.id}`}
                            class="details-link"
                        >
                            Project Details &rarr;
                        </a>
                    </div>
                </article>
            ))
        }
    </section>
</Layout>

<style>
    h1 {
        font-size: 2.5rem;
        margin: 0;
    }
    .subtitle {
        color: var(--text-muted);
        margin-bottom: 3rem;
    }
    .projects-list {
        display: flex;
        flex-direction: column;
        gap: 3.5rem;
    }
    .project-item {
        padding-bottom: 2.5rem;
        border-bottom: 1px dashed var(--border);
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 2rem;
    }
    .project-item:last-child {
        border-bottom: none;
    }
    .post-link {
        text-decoration: none;
        color: inherit;
    }
    .post-link:hover h3 {
        color: var(--accent);
        text-decoration: underline;
    }
    h3 {
        font-size: 1.75rem;
        margin: 0 0 1rem 0;
        line-height: 1.2;
        font-weight: 700;
        letter-spacing: -0.01em;
    }
    .project-content p {
        line-height: 1.6;
        opacity: 0.9;
    }
    .tech-stack {
        margin-top: 1.25rem;
        display: flex;
        gap: 0.5rem 1.25rem;
        flex-wrap: wrap;
    }
    .tech-item {
        font-size: 0.85rem;
        color: var(--text-muted);
        font-weight: 600;
    }
    .project-links a {
        font-weight: 700;
        text-decoration: none;
        color: var(--foreground);
        font-size: 0.9rem;
        transition: color 0.2s;
        white-space: nowrap;
    }
    .project-links a:hover {
        color: var(--accent);
        text-decoration: underline;
    }
</style>
