---
import { LIGHT_THEMES, DARK_THEMES } from "../../config";
import DevToolsLayout from "../../layouts/DevToolsLayout.astro";

if (import.meta.env.PROD) {
    return new Response(null, {
        status: 404,
        statusText: "Not found",
    });
}

const themes = {
    ...Object.fromEntries(
        Object.entries(LIGHT_THEMES).map(([k, v]) => [`Light - ${k}`, v]),
    ),
    ...Object.fromEntries(
        Object.entries(DARK_THEMES).map(([k, v]) => [`Dark - ${k}`, v]),
    ),
};
---

<DevToolsLayout title="Color Palettes" description="Minimalist 6-color strip visualizer directly mapping to themes.ts">

            <div class="flex flex-col gap-16">
                {
                    Object.entries(themes).map(([name, colors]) => (
                        <div>
                            <h2 class="text-xl font-bold mb-4 capitalize">
                                {name}
                            </h2>
                            <div class="flex flex-wrap gap-4">
                                {Object.entries(colors).map(
                                    ([varName, hexValue]) => (
                                        <div class="flex flex-col gap-2">
                                            <div
                                                class="w-32 h-32 rounded-2xl shadow-sm transition-all duration-300 relative z-0 hover:z-10 hover:-translate-y-2 hover:shadow-xl cursor-pointer flex-shrink-0"
                                                style={`background-color: ${hexValue}`}
                                                title={`${varName}:\n${hexValue}`}
                                            />
                                            <div class="text-left px-1">
                                                <div class="font-mono text-sm font-bold opacity-80">{varName}</div>
                                                <div class="font-mono text-xs opacity-50 uppercase">{hexValue}</div>
                                            </div>
                                        </div>
                                    ),
                                )}
                            </div>
                        </div>
                    ))
                }
            </div>
</DevToolsLayout>
