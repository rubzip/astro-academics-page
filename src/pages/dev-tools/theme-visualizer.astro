---
import { LIGHT_THEMES, DARK_THEMES } from "../../themes";
import "../../styles/global.css";

if (import.meta.env.PROD) {
    return new Response(null, {
        status: 404,
        statusText: "Not found",
    });
}
---

<!doctype html>
<html lang="es">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Theme Visualizer - Embed Previews</title>
        <style>
            .iframe-container {
                position: relative;
                width: 100%;
                padding-top: 56.25%; /* 16:9 Aspect Ratio */
                overflow: hidden;
                border-radius: 0.75rem;
                border: 1px solid #eee;
                background: #fff;
            }
            .iframe-container iframe {
                position: absolute;
                top: 0;
                left: 0;
                width: 200%;
                height: 200%;
                transform: scale(0.5);
                transform-origin: 0 0;
                border: none;
            }
        </style>
    </head>
    <body class="bg-white text-gray-800 font-sans p-10 min-h-screen">
        <div class="max-w-6xl mx-auto">
            <header
                class="mb-12 flex flex-col gap-2 border-b border-gray-200 pb-5"
            >
                <h1 class="text-3xl font-bold text-gray-800">Theme Previews</h1>
                <p class="text-gray-500 font-mono text-sm">
                    Live iframe previews of <code>index.astro</code> for all defined
                    themes.
                </p>
            </header>

            <div class="mb-16">
                <h2
                    class="text-xl font-bold mb-8 text-gray-700 uppercase tracking-widest border-l-4 border-accent pl-4"
                >
                    Light Themes
                </h2>
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
                    {
                        Object.entries(LIGHT_THEMES).map(
                            ([themeName, colors]) => (
                                <div class="flex flex-col gap-2">
                                    <h3 class="text-sm font-mono font-bold text-gray-500 uppercase tracking-tighter">
                                        {themeName}
                                    </h3>
                                    <div class="iframe-container">
                                        <iframe
                                            src={`/?force_mode=light`}
                                            title={`${themeName} Light Preview`}
                                            loading="lazy"
                                            onload={`
                                const doc = this.contentDocument.documentElement;
                                doc.setAttribute('data-theme', 'light');
                                doc.style.setProperty('--background', '${colors.background}');
                                doc.style.setProperty('--foreground', '${colors.foreground}');
                                doc.style.setProperty('--accent', '${colors.accent}');
                                doc.style.setProperty('--text-muted', '${colors.muted}');
                                doc.style.setProperty('--border', '${colors.border}');
                                doc.style.setProperty('--surface', '${colors.surface}');
                            `}
                                        />
                                    </div>
                                </div>
                            ),
                        )
                    }
                </div>
            </div>

            <div class="mb-16 mt-24">
                <h2
                    class="text-xl font-bold mb-8 text-gray-700 uppercase tracking-widest border-l-4 border-accent pl-4"
                >
                    Dark Themes
                </h2>
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
                    {
                        Object.entries(DARK_THEMES).map(
                            ([themeName, colors]) => (
                                <div class="flex flex-col gap-2">
                                    <h3 class="text-lg font-bold text-slate-300 capitalize">
                                        {themeName}
                                    </h3>
                                    <div class="iframe-container border-gray-100">
                                        <iframe
                                            src={`/?force_mode=dark`}
                                            title={`${themeName} Dark Preview`}
                                            loading="lazy"
                                            onload={`
                                const doc = this.contentDocument.documentElement;
                                doc.setAttribute('data-theme', 'dark');
                                doc.style.setProperty('--background', '${colors.background}');
                                doc.style.setProperty('--foreground', '${colors.foreground}');
                                doc.style.setProperty('--accent', '${colors.accent}');
                                doc.style.setProperty('--text-muted', '${colors.muted}');
                                doc.style.setProperty('--border', '${colors.border}');
                                doc.style.setProperty('--surface', '${colors.surface}');
                            `}
                                        />
                                    </div>
                                </div>
                            ),
                        )
                    }
                </div>
            </div>
        </div>
    </body>
</html>
