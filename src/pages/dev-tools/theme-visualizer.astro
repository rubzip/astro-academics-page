---
import { THEMES, SETTINGS } from "../../config";
import DevToolsLayout from "../../layouts/DevToolsLayout.astro";

const redirect: boolean = import.meta.env.PROD && !SETTINGS.addDevToolsInProduction;
if (redirect) {
    return Astro.redirect("/404");
}

const lightThemes = Object.entries(THEMES).filter(([_, t]) => !t.isDark);
const darkThemes = Object.entries(THEMES).filter(([_, t]) => t.isDark);
---

<DevToolsLayout title="Theme Visualizer" description="Live iframe previews of index.astro for all defined themes.">

            <div class="mb-16">
                <h2
                    class="text-xl font-bold mb-8 uppercase tracking-widest pl-4"
                >
                    Light Themes
                </h2>
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
                    {
                        lightThemes.map(
                            ([themeName, colors]: [string, any]) => (
                                <div class="flex flex-col gap-2">
                                    <h3 class="text-sm font-mono font-bold text-gray-500 uppercase tracking-tighter">
                                        {themeName.replace('light_', '')}
                                    </h3>
                                    <div class="iframe-container">
                                        <iframe
                                            src={`/?force_mode=light`}
                                            title={`${themeName} Light Preview`}
                                            loading="lazy"
                                            onload={`
                                const doc = this.contentDocument.documentElement;
                                doc.setAttribute('data-theme', 'light');
                                doc.style.setProperty('--background', '${colors.background}');
                                doc.style.setProperty('--foreground', '${colors.foreground}');
                                doc.style.setProperty('--accent', '${colors.accent}');
                                doc.style.setProperty('--text-muted', '${colors.muted}');
                                doc.style.setProperty('--border', '${colors.border}');
                                doc.style.setProperty('--surface', '${colors.surface}');
                            `}
                                        />
                                    </div>
                                </div>
                            ),
                        )
                    }
                </div>
            </div>

            <div class="mb-16 mt-24">
                <h2
                    class="text-xl font-bold mb-8 uppercase tracking-widest pl-4"
                >
                    Dark Themes
                </h2>
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
                    {
                        darkThemes.map(
                            ([themeName, colors]: [string, any]) => (
                                <div class="flex flex-col gap-2">
                                    <h3 class="text-lg font-bold text-slate-300 capitalize">
                                        {themeName.replace('dark_', '')}
                                    </h3>
                                    <div class="iframe-container border-gray-100">
                                        <iframe
                                            src={`/?force_mode=dark`}
                                            title={`${themeName} Dark Preview`}
                                            loading="lazy"
                                            onload={`
                                const doc = this.contentDocument.documentElement;
                                doc.setAttribute('data-theme', 'dark');
                                doc.style.setProperty('--background', '${colors.background}');
                                doc.style.setProperty('--foreground', '${colors.foreground}');
                                doc.style.setProperty('--accent', '${colors.accent}');
                                doc.style.setProperty('--text-muted', '${colors.muted}');
                                doc.style.setProperty('--border', '${colors.border}');
                                doc.style.setProperty('--surface', '${colors.surface}');
                            `}
                                        />
                                    </div>
                                </div>
                            ),
                        )
                    }
                </div>
            </div>
</DevToolsLayout>