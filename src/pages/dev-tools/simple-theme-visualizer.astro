---

<DevToolsLayout title="Simple Theme Visualizer" description="Simple HTML previews of theme colors.">
    <div class="mb-12">
        <p class="text-foreground opacity-80 mb-8">
            A simpler theme visualizer showing sample UI elements with theme colors.
            Each preview loads minimal HTML with global styles.
        </p>
    </div>

    <div class="mb-16">
        <h2
            class="text-xl font-bold mb-8 uppercase tracking-widest border-l-4 border-accent pl-4"
        >
            Light Themes
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            {
                lightThemes.map(([themeName, colors]: [string, any]) => (
                    <div class="flex flex-col gap-3">
                        <h3 class="text-sm font-mono font-bold text-gray-500 uppercase tracking-tighter">
                            {themeName.replace("light_", "")}
                        </h3>
                        <div class="border border-border rounded-lg overflow-hidden">
                            <iframe
                                srcdoc={sampleHtmlLight.replace(
                                    "</head>",
                                    `<style>
                                        :root {
                                            --background: ${colors.background};
                                            --foreground: ${colors.foreground};
                                            --accent: ${colors.accent};
                                            --text-muted: ${colors.muted};
                                            --border: ${colors.border};
                                            --surface: ${colors.surface};
                                        }
                                    </style></head>`,
                                )}
                                title={`${themeName} Preview`}
                                class="w-full h-64 border-0"
                            />
                        </div>
                    </div>
                ))
            }
        </div>
    </div>

    <div class="mb-16">
        <h2
            class="text-xl font-bold mb-8 uppercase tracking-widest border-l-4 border-accent pl-4"
        >
            Dark Themes
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            {
                darkThemes.map(([themeName, colors]: [string, any]) => (
                    <div class="flex flex-col gap-3">
                        <h3 class="text-sm font-mono font-bold text-gray-400 uppercase tracking-tighter">
                            {themeName.replace("dark_", "")}
                        </h3>
                        <div class="border border-border rounded-lg overflow-hidden">
                            <iframe
                                srcdoc={sampleHtmlDark.replace(
                                    "</head>",
                                    `<style>
                                        [data-theme="dark"] {
                                            --background: ${colors.background};
                                            --foreground: ${colors.foreground};
                                            --accent: ${colors.accent};
                                            --text-muted: ${colors.muted};
                                            --border: ${colors.border};
                                            --surface: ${colors.surface};
                                        }
                                    </style></head>`,
                                )}
                                title={`${themeName} Preview`}
                                class="w-full h-64 border-0"
                            />
                        </div>
                    </div>
                ))
            }
        </div>
    </div>
</DevToolsLayout>