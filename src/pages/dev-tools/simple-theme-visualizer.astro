        <p class="sample-desc">This is a sample description with some text to preview how the theme colors look in paragraphs and content.</p>
        <div class="sample-tags">
            <span class="sample-tag">#tag1</span>
            <span class="sample-tag">#tag2</span>
        </div>
        <a href="#" class="sample-btn">Sample Button</a>
    </div>
    <div class="color-swatches">
        <div class="swatch-group">
            <div class="swatch" style="background: var(--background)"></div>
            <span class="swatch-label">bg</span>
        </div>
        <div class="swatch-group">
            <div class="swatch" style="background: var(--foreground)"></div>
            <span class="swatch-label">fg</span>
        </div>
        <div class="swatch-group">
            <div class="swatch" style="background: var(--accent)"></div>
            <span class="swatch-label">accent</span>
        </div>
        <div class="swatch-group">
            <div class="swatch" style="background: var(--text-muted)"></div>
            <span class="swatch-label">muted</span>
        </div>
        <div class="swatch-group">
            <div class="swatch" style="background: var(--border)"></div>
            <span class="swatch-label">border</span>
        </div>
        <div class="swatch-group">
            <div class="swatch" style="background: var(--surface)"></div>
            <span class="swatch-label">surface</span>
        </div>
    </div>
