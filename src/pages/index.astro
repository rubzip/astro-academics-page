---
import { getEntry, render } from "astro:content";
import Layout from "../layouts/Layout.astro";

// Load bio content
const bioEntry = await getEntry("bio", "bio");
const { Content: BioContent } = bioEntry
	? await render(bioEntry)
	: { Content: null };
---

<Layout title="Home">
	<section class="bio container-narrow py-12">
		<div class="prose">
			{BioContent ? <BioContent /> : <p>Loading bio...</p>}
		</div>
	</section>
</Layout>
