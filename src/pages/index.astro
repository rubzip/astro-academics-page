---
import { getEntry, render } from "astro:content";
import Layout from "../layouts/Layout.astro";
import { PAGES } from "../config";

// Load bio content
const bioEntry = await getEntry("bio", "bio");
const { Content: BioContent } = bioEntry
	? await render(bioEntry)
	: { Content: null };
---

<Layout title={PAGES.home.title}>
	<div class="container-narrow">
		<header class="page-header">
			<h1 class="page-title">{PAGES.home.title}</h1>
			{
				PAGES.home.subtitle && (
					<p class="page-subtitle">{PAGES.home.subtitle}</p>
				)
			}
		</header>
		<div class="prose">
			{BioContent ? <BioContent /> : <p>Loading bio...</p>}
		</div>
	</div>
</Layout>
