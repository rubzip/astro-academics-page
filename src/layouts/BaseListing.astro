---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import BaseItemCard from "../components/ui/BaseItemCard.astro";
import { getUnifiedItem } from "../utils/adapters";

interface Props {
    collection:
        | "publications"
        | "talks"
        | "projects"
        | "posts"
        | "teaching"
        | "all";
    title: string;
    subtitle?: string;
    entries?: any[];
    page?: any;
}

const {
    collection,
    title,
    subtitle,
    entries: manualEntries,
    page,
} = Astro.props;

let entries =
    manualEntries ||
    (collection !== "all" ? await getCollection(collection as any) : []);
if (page) {
    entries = page.data;
}

// Generic sorting logic
const sortedEntries = entries.sort((a: any, b: any) => {
    const dateA =
        a.data.publicationDate || a.data.date || a.data.pubDate || new Date(0);
    const dateB =
        b.data.publicationDate || b.data.date || b.data.pubDate || new Date(0);
    return dateB.getTime() - dateA.getTime();
});
---

<BaseLayout title={title}>
    {
        (title || subtitle) && (
            <header class="page-header">
                {title && <h1 class="page-title">{title}</h1>}
                {subtitle && <p class="page-subtitle">{subtitle}</p>}
            </header>
        )
    }

    <section class="item-list">
        {
            sortedEntries.map((entry: any) => (
                <BaseItemCard {...getUnifiedItem(entry, collection)} />
            ))
        }
    </section>

    {
        page && page.lastPage > 1 && (
            <nav class="pagination container-narrow flex justify-center items-center mt-20 pt-12 border-t border-dashed border-border gap-8">
                {page.url.prev ? (
                    <a
                        href={page.url.prev}
                        class="font-bold hover:text-accent transition-colors"
                    >
                        &larr; Newer
                    </a>
                ) : (
                    <span class="opacity-30 cursor-not-allowed font-bold">
                        &larr; Newer
                    </span>
                )}

                <div class="page-count opacity-75 font-medium mx-4">
                    Page {page.currentPage} of {page.lastPage}
                </div>

                {page.url.next ? (
                    <a
                        href={page.url.next}
                        class="font-bold hover:text-accent transition-colors"
                    >
                        Older &rarr;
                    </a>
                ) : (
                    <span class="opacity-30 cursor-not-allowed font-bold">
                        Older &rarr;
                    </span>
                )}
            </nav>
        )
    }
</BaseLayout>
